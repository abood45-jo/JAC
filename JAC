let calYear=new Date().getFullYear(),calMonth=new Date().getMonth()+1;
function renderCalendar(){
  document.getElementById('calendar-title').textContent=`${MONTHS[calMonth-1]} ${calYear}`;
  const days=new Date(calYear,calMonth,0).getDate(),first=new Date(calYear,calMonth-1,1).getDay(),today=new Date();
  const cells=[];for(let i=0;i<first;i++)cells.push(null);for(let d=1;d<=days;d++)cells.push(d);while(cells.length%7)cells.push(null);
  document.getElementById('calendar-grid').innerHTML=cells.map(d=>{
    if(!d)return'<div></div>';
