      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:800;color:${inTeam?'#fff':'var(--text)'};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHTML(a.ar)}</div>
        <div style="font-size:9.5px;color:${inTeam?'rgba(255,255,255,.8)':'var(--text-muted)'};white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHTML(a.en)}</div>
      </div>
      ${inTeam?'<div style="color:#fff;font-size:15px;flex-shrink:0">✓</div>':''}
    </div>`;
  }).join('') || `<div style="text-align:center;padding:30px 10px;color:var(--text-muted);font-size:12px">لا نتائج مطابقة</div>`;
}
function toggleAnimeTeamByIndex(i){
  const a = currentAnimeFiltered[i];
  if(!a) return;
  const idx = animeTeam.findIndex(t => t.en === a.en);
  if(idx >= 0){
    animeTeam.splice(idx,1);
  } else {
    if(animeTeam.length >= ANIME_TEAM_MAX){ showToast(`الحد الأقصى ${ANIME_TEAM_MAX} في الفريق — أزل واحدًا أولاً`,'error'); return; }
    animeTeam.push(a);
  }
  saveAnimeTeam();
  renderAnimeTeamRow();
  renderAnimeList();
}

function getInitials(name){const p=String(name||'').trim().split(/\s+/);if(p.length>=2)return(p[0][0]||'')+(p[1][0]||'');return(p[0]||'?').slice(0,2);}
function escapeHTML(t){const d=document.createElement('div');d.textContent=t;return d.innerHTML;}
function normalizeArabic(t){return String(t||'').toLowerCase().replace(/[أإآا]/g,'ا').replace(/ى/g,'ي').replace(/ة/g,'ه').replace(/[ً-ْ]/g,'').replace(/\s+/g,' ').trim();}
