function makeCoverSVG(stops, shapes){
  const grad = `<linearGradient id="g" x1="0" y1="0" x2="1" y2="1">${stops.map(s=>`<stop offset="${s.o}" stop-color="${s.c}"/>`).join('')}</linearGradient>`;
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 180"><defs>${grad}</defs><rect width="320" height="180" fill="url(#g)"/>${shapes}</svg>`;
}
