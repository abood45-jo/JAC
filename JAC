/* ── ADDITIONAL IMPROVEMENTS v2.4.0 ── */
/* Smooth scroll for all scrollers */
.scroller { scroll-behavior: smooth; }

/* Nav bar glass effect */
#nav-bar { 
  background: rgba(17,14,32,0.92); 
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

/* Ripple effect on buttons */
.button { position: relative; overflow: hidden; }
.button::after { content: ''; position: absolute; inset: 0; background: rgba(255,255,255,.12); opacity: 0; border-radius: inherit; transition: opacity .3s; }
.button:active::after { opacity: 1; transition: opacity 0s; }

/* Finance card hover glow */
#finance-list .card { transition: border-color .25s, box-shadow .25s; }

/* Stat boxes count-up shimmer on load */
.stat-number { transition: color .4s ease; }

/* Better scrollbar */
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: linear-gradient(180deg,var(--primary),var(--accent)); border-radius: 3px; }

/* Member count badge in tabs */
.tab { position: relative; }

/* Card hover state desktop */
@media (hover: hover) {
  .member-row:hover { background: var(--bg-lightest); border-color: rgba(124,58,237,.35); transform: translateY(-1px); }
  .stat-box:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.12); }
  .jac-action-item:hover { background: rgba(255,255,255,.07); }
}

/* Attendance toggle animation */
button[onclick^="toggleAttendance"] { will-change: background, color; }

/* Overlay blur improvement */
.modal { backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }

/* Sheet swipe indicator */
.modal-handle { cursor: grab; }

/* Improved toast */
#toast { box-shadow: 0 8px 32px rgba(0,0,0,.4); }

/* Quick amount buttons pressed */
.quick-btn { user-select: none; }

/* Page transition */
.screen.active { animation: slideIn .22s cubic-bezier(.22,1,.36,1); }

/* Profile header gradient depth */
.profile-banner-bg { position: relative; overflow: hidden; }
