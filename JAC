      const dm=members.filter(m=>m.dept===d.id);
      if(!dm.length)return;
      const dt=dm.map(m=>calculateMemberBalance(m));
      const dPaid=dt.reduce((s,t)=>s+t.paid,0), dReq=dt.reduce((s,t)=>s+t.required,0);
      const rows=dm.map((m,i)=>{
        const b=calculateMemberBalance(m);
        const label=b.balance>=0?'مسدد':b.paid>0?'جزئي':'متأخر';
        const color=b.balance>=0?'#059669':b.paid>0?'#D97706':'#DC2626';
        return `<tr style="background:${i%2?'#F8F8FA':'#FFFFFF'}">
          <td style="padding:7px 9px;border-bottom:1px solid #E5E7EB;font-weight:700;color:#111827">${escapeHTML(m.name)}</td>
          <td style="padding:7px 9px;border-bottom:1px solid #E5E7EB;text-align:center;color:#374151">${b.required.toFixed(2)}</td>
          <td style="padding:7px 9px;border-bottom:1px solid #E5E7EB;text-align:center;color:#374151">${b.paid.toFixed(2)}</td>
          <td style="padding:7px 9px;border-bottom:1px solid #E5E7EB;text-align:center;font-weight:800;color:${b.balance>=0?'#059669':'#DC2626'}">${b.balance>=0?'+':''}${b.balance.toFixed(2)}</td>
          <td style="padding:7px 9px;border-bottom:1px solid #E5E7EB;text-align:center"><span style="display:inline-block;padding:2px 10px;border-radius:20px;font-size:10px;font-weight:800;color:#fff;background:${color}">${label}</span></td>
        </tr>`;
      }).join('');
      deptSections+=`
      <div style="margin-top:16px">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:9px 12px;background:${primary};border-radius:8px 8px 0 0">
          <span style="color:#fff;font-weight:900;font-size:13px">${escapeHTML(d.name)}</span>
          <span style="color:#fff;font-size:11px;opacity:.9">${dm.length} عضو &middot; مسدد ${dPaid.toFixed(2)} / ${dReq.toFixed(2)} د.أ</span>
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:11.5px;background:#fff">
          <thead>
            <tr style="background:#F1F1F4">
              <th style="padding:7px 9px;text-align:right;color:#4B5563;font-size:10px;font-weight:800">الاسم</th>
              <th style="padding:7px 9px;text-align:center;color:#4B5563;font-size:10px;font-weight:800">المطلوب</th>
              <th style="padding:7px 9px;text-align:center;color:#4B5563;font-size:10px;font-weight:800">المسدد</th>
              <th style="padding:7px 9px;text-align:center;color:#4B5563;font-size:10px;font-weight:800">الرصيد</th>
              <th style="padding:7px 9px;text-align:center;color:#4B5563;font-size:10px;font-weight:800">الحالة</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>`;
    });

    container=document.createElement('div');
    container.style.cssText='position:absolute;left:-10000px;top:0;width:780px;background:#FFFFFF;font-family:Cairo,Tahoma,Arial,sans-serif;direction:rtl;color:#111827';
    container.innerHTML=`
      <div style="padding:26px 30px;background:linear-gradient(135deg,${primary},${primary})">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div>
            <div style="color:#fff;font-size:22px;font-weight:900">نادي اليابان والأنمي — JAC</div>
            <div style="color:rgba(255,255,255,.85);font-size:12.5px;margin-top:4px">التقرير المالي الشامل</div>
          </div>
          <div style="text-align:left;color:rgba(255,255,255,.85);font-size:11px">${dateStr}</div>
        </div>
      </div>
      <div style="padding:20px 30px 4px">
        <div style="display:flex;gap:10px;margin-bottom:16px">
          <div style="flex:1;background:#F8F8FA;border:1px solid #E5E7EB;border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:20px;font-weight:900;color:${primary}">${members.length}</div>
            <div style="font-size:10px;color:#6B7280;margin-top:2px">إجمالي الأعضاء</div>
          </div>
          <div style="flex:1;background:#F8F8FA;border:1px solid #E5E7EB;border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:20px;font-weight:900;color:#059669">${tPaid.toFixed(1)}</div>
            <div style="font-size:10px;color:#6B7280;margin-top:2px">إجمالي المسدد (د.أ)</div>
          </div>
          <div style="flex:1;background:#F8F8FA;border:1px solid #E5E7EB;border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:20px;font-weight:900;color:${accent}">${tReq.toFixed(1)}</div>
            <div style="font-size:10px;color:#6B7280;margin-top:2px">إجمالي المطلوب (د.أ)</div>
          </div>
          <div style="flex:1;background:#F8F8FA;border:1px solid #E5E7EB;border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:20px;font-weight:900;color:#DC2626">${tOverdue.toFixed(1)}</div>
            <div style="font-size:10px;color:#6B7280;margin-top:2px">إجمالي المتأخرات (د.أ)</div>
          </div>
        </div>
        <div style="background:#F8F8FA;border:1px solid #E5E7EB;border-radius:10px;padding:12px 14px;margin-bottom:6px">
          <div style="display:flex;justify-content:space-between;margin-bottom:7px">
            <span style="font-size:12px;font-weight:800;color:#374151">نسبة التحصيل الإجمالية</span>
            <span style="font-size:13px;font-weight:900;color:${primary}">${pct}%</span>
          </div>
          <div style="height:9px;background:#E5E7EB;border-radius:6px;overflow:hidden">
            <div style="height:100%;width:${pct}%;background:linear-gradient(90deg,${primary},#059669)"></div>
          </div>
        </div>
        ${deptSections}
        <div style="margin-top:20px;padding-top:12px;border-top:1px solid #E5E7EB;text-align:center;font-size:9.5px;color:#9CA3AF">
          JAC Jordan &middot; تم إنشاء هذا التقرير تلقائيًا بتاريخ ${new Date().toLocaleString('en-GB')}
        </div>
      </div>`;
    document.body.appendChild(container);

    // let fonts/layout settle before the snapshot
    await new Promise(r=>setTimeout(r,80));

    const canvas=await html2canvas(container,{scale:2,useCORS:true,backgroundColor:'#ffffff'});
    document.body.removeChild(container);
    container=null;

    const{jsPDF}=window.jspdf;
    const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
    const pageW=210, pageH=297;
    const imgW=pageW;
    const imgH=canvas.height*imgW/canvas.width;
    const imgData=canvas.toDataURL('image/png');
    const totalPages=Math.max(1,Math.ceil(imgH/pageH));
    const addFooter=(pageNum)=>{
      doc.setFontSize(8);
      doc.setTextColor(160,160,170);
      doc.text(`JAC Club  -  Page ${pageNum} / ${totalPages}`,pageW/2,292,{align:'center'});
    };

    let heightLeft=imgH, position=0, pageNum=1;
    doc.addImage(imgData,'PNG',0,position,imgW,imgH);
    addFooter(pageNum);
    heightLeft-=pageH;
    while(heightLeft>0){
      position=heightLeft-imgH;
      doc.addPage();
      pageNum++;
      doc.addImage(imgData,'PNG',0,position,imgW,imgH);
      addFooter(pageNum);
      heightLeft-=pageH;
    }

    doc.save(`JAC_Report_${new Date().toISOString().slice(0,10)}.pdf`);
    showToast('✓ تم تصدير PDF بنجاح');
  }catch(e){
    if(container&&container.parentNode) document.body.removeChild(container);
    showToast('خطأ في PDF: '+e.message,'error');
  }
}

