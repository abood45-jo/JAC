  return `<div class="level-bar-wrap"><div class="level-bar-label"><span>${lv.min}</span><span>${nextTxt}</span></div><div style="height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,${lv.color},#fff);border-radius:3px;transition:width .5s ease;box-shadow:0 0 8px ${lv.glow}"></div></div></div>`;
}

