function dismissPWABar(){var b=document.getElementById("pwa-install-bar");if(b)b.remove();}
function installPWA(){
  if(!_pwaInstallPrompt)return;
  _pwaInstallPrompt.prompt();
  _pwaInstallPrompt.userChoice.then(()=>{_pwaInstallPrompt=null;const b=document.getElementById('pwa-install-bar');if(b)b.remove();});
}

