  if(btn){btn.classList.toggle('active',membersSearchAll);btn.title=membersSearchAll?'البحث في كل الأقسام':'البحث داخل القسم الحالي';}
  renderMembers();
}
function renderMembers(){
  const q=(document.getElementById('search-members')?.value||'').trim();
  const nq=normalizeArabic(q);
  const filtered=members.filter(m=>{
    const inScope=membersSearchAll||m.dept===currentDept;
    if(!inScope)return false;
    if(!nq)return true;
    return [m.name,m.phone,m.email,getDeptName(m.dept)].some(v=>normalizeArabic(v).includes(nq));
  });
  // Apply sort
  if(memberSortMode===1) filtered.sort((a,b)=>{const ba=calculateMemberBalance(a),bb=calculateMemberBalance(b);return bb.paid-ba.paid;});
  else if(memberSortMode===2) filtered.sort((a,b)=>{const ba=calculateMemberBalance(a),bb=calculateMemberBalance(b);return ba.balance-bb.balance;});
  const scope=membersSearchAll?'كل الأقسام':getDeptName(currentDept);
  document.getElementById('members-subtitle').textContent=`${filtered.length} عضو في ${scope}`;
  const list=document.getElementById('members-list');
  if(!filtered.length){list.innerHTML='<div style="text-align:center;padding:40px;color:var(--text-muted)">لا توجد نتائج</div>';return;}
  list.innerHTML=filtered.map(m=>{
    const b=calculateMemberBalance(m);
    const pts=m.points||0, lv=getMemberLevel(pts);
    const sb=b.balance>=0?'<span class="badge badge-success">مسدد</span>':b.paid>0?'<span class="badge badge-warning">جزئي</span>':'<span class="badge badge-danger">متأخر</span>';
    const lvBadge=renderLevelBadge(pts,true);
    const theme=m.animeTheme?ANIME_THEMES.find(t=>t.id===m.animeTheme):null;
    const themeChip=theme?`<span style="font-size:9px;background:${theme.colors[0]};border:1px solid ${theme.accent};border-radius:20px;padding:1px 6px;color:${theme.accent}">${theme.emoji} ${theme.name}</span>`:'';
    const deptChip=membersSearchAll?`<span class="dept-chip" style="background:${getDeptColor(m.dept)}22;color:${getDeptColor(m.dept)}">${getDeptIcon(m.dept)} ${getDeptName(m.dept)}</span>`:'';
    const lvIdx9=LEVELS.indexOf(lv);
    return`<div class="member-row${q?' search-hit':''}" data-level="${lvIdx9}" onclick="openMemberProfile('${m.id}')" style="border-right:${lvIdx9>=7?'4':'3'}px solid ${lv.color};${lvIdx9>=8?'box-shadow:0 0 12px '+lv.color+'33':''}">${renderAvatarHTML(m,48,16)}<div style="flex:1;min-width:0"><div style="font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px">${escapeHTML(m.name)}</div><div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap">${sb}${lvBadge}${themeChip}${deptChip}</div></div><div style="text-align:center;flex-shrink:0;min-width:50px"><div style="font-size:14px;font-weight:900;color:${b.balance>=0?'var(--green)':'var(--red)'}">${b.balance>=0?'+':''}${b.balance.toFixed(1)}</div><div style="font-size:9px;color:var(--text-muted)">د.أ</div><button onclick="event.stopPropagation();openPaymentFor('${m.id}')" style="margin-top:3px;background:rgba(124,58,237,.2);color:var(--primary);border:none;border-radius:6px;padding:3px 7px;cursor:pointer;font-size:10px;font-family:inherit;font-weight:700">+دفع</button></div></div>`;
  }).join('');
}

