// ── HOME ──
function renderHome(){
  const now=new Date();
  document.getElementById('current-date').textContent=now.toLocaleDateString('ar-JO',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const tm=now.getMonth()+1,td=now.getDate();
  const bdays=members.filter(m=>{if(!m.dob)return false;const p=m.dob.split('-');return+p[1]===tm&&+p[2]===td;});
  const bdSec=document.getElementById('birthdays-section');
  if(bdays.length>0){
    bdSec.style.display='block';
    document.getElementById('birthdays-list').innerHTML=bdays.map(m=>`<div onclick="openMemberProfile('${m.id}')" style="display:flex;align-items:center;gap:9px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.1);cursor:pointer">${renderAvatarHTML(m,32,10)}<span style="font-size:13px;font-weight:700">${escapeHTML(m.name)}</span><span style="font-size:10px;opacity:.6;margin-right:auto">${getDeptName(m.dept)}</span></div>`).join('');
  } else bdSec.style.display='none';
  const totals=members.map(m=>calculateMemberBalance(m));
  const tPaid=+totals.reduce((s,t)=>s+t.paid,0).toFixed(1);
  const tReq=+totals.reduce((s,t)=>s+t.required,0).toFixed(1);
  const tOvd=+totals.filter(t=>t.balance<0).reduce((s,t)=>s+Math.abs(t.balance),0).toFixed(1);
  const pct=tReq>0?Math.round((tPaid/tReq)*100):0;
  document.getElementById('stat-total').textContent=members.length;
  document.getElementById('stat-paid').textContent=tPaid;
  document.getElementById('stat-required').textContent=tReq;
  document.getElementById('stat-overdue').textContent=tOvd;
  document.getElementById('collection-percent').textContent=pct+'%';
  document.getElementById('collection-bar').style.width=pct+'%';
  document.getElementById('departments-grid').innerHTML=DEPARTMENTS.map(dept=>{
    const dm=members.filter(m=>m.dept===dept.id);if(!dm.length)return'';
    const dt=dm.map(m=>calculateMemberBalance(m));
    const dp=+dt.reduce((s,t)=>s+t.paid,0).toFixed(1);
    const dr=+dt.reduce((s,t)=>s+t.required,0).toFixed(1);
    const db=+(dp-dr).toFixed(1);
    const dpct=dr>0?Math.min(100,Math.round((dp/dr)*100)):0;
    return`<div onclick="currentDept='${dept.id}';goToPage('members')" style="background:var(--card);border:1px solid var(--border);border-top:3px solid ${dept.color};border-radius:var(--radius-lg);padding:12px;cursor:pointer"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px"><span style="font-size:18px">${dept.icon}</span><span style="font-size:12px;font-weight:800;color:${db>=0?'var(--green)':'var(--red)'}">${db>=0?'+':''}${db}</span></div><div style="font-size:11px;font-weight:700;color:${dept.color};margin-bottom:2px">${dept.name}</div><div style="font-size:10px;color:var(--text-muted);margin-bottom:7px">${dm.length} عضو • ${dpct}%</div><div class="progress-bar"><div class="progress-fill" style="background:${dept.color};width:${dpct}%"></div></div></div>`;
  }).join('');
}

