function getCover(id){
  if(!id) return null;
  if(id.startsWith('data:image')) return { id, custom:true, name:'صورة مخصصة' };
  return COVER_LIBRARY.find(c=>c.id===id);
}
function coverDataUri(cover){
  if(!cover) return '';
  if(cover.custom) return cover.id; // already a data URI
  return svgToDataUri(cover.svg);
}

