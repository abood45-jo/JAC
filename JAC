// ── DATA ──
function sanitizeMember(m){
  if(!m.nList)m.nList=[];
  if(!m.files)m.files=[];
  if(!m.payments)m.payments=[];
  if(m.lP===undefined)m.lP=0;
  if(m.lR===undefined)m.lR=0;
  if(!m.photo)m.photo='';
  if(!m.phone)m.phone='';
  if(!m.email)m.email='';
  if(!m.dob)m.dob='';
  if(m.cover===undefined)m.cover='';
  if(m.animeTheme===undefined)m.animeTheme='';
  if(m.points===undefined)m.points=0;
  if(!m.achievements)m.achievements=[];
  return m;
}

function buildDefaultMembers(){
  return DEFAULT_MEMBERS.map(d=>sanitizeMember({
    ...d,
    photo:'',
    nList:[],
    files:[],
    payments:[],
  }));
}

function saveData(){
  try{
    localStorage.setItem('jac-club-v2',JSON.stringify({members,sessions,cloudSettings,appVersion:APP_VERSION}));
    clearTimeout(_autoSyncTimer);
    if(cloudSettings.apiKey&&cloudSettings.binId)_autoSyncTimer=setTimeout(uploadToCloudSilent,5000);
  }catch(e){showToast('خطأ في الحفظ!','error');}
}

function loadData(){
  try{
    let s=localStorage.getItem('jac-club-v2')||localStorage.getItem('jac-club-v1');
    if(s){
      const d=JSON.parse(s);
      members=(d.members||[]).map(sanitizeMember);
      sessions=d.sessions||{};
      cloudSettings=d.cloudSettings||{apiKey:'',binId:''};
      // If no members saved, seed with defaults
      if(members.length===0){
        members=buildDefaultMembers();
        saveData();
      }
    } else {
      // First run — seed with defaults
      members=buildDefaultMembers();
      sessions={};
      cloudSettings={apiKey:'',binId:''};
      saveData();
    }
  }catch(e){
    members=buildDefaultMembers();
    sessions={};
    cloudSettings={apiKey:'',binId:''};
  }
}

function resetToDefaults(){
  showConfirm('سيتم مسح جميع البيانات واستعادة الأعضاء الأصليين. متأكد؟',()=>{
    members=buildDefaultMembers();
