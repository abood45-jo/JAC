function compressImage(file,maxSize=220){
  return new Promise(resolve=>{
    const r=new FileReader();
    r.onload=e=>{
      const img=new Image();
      img.onload=()=>{
        const c=document.createElement('canvas');
        let w=img.width,h=img.height;
        if(w>h){if(w>maxSize){h=h*maxSize/w;w=maxSize;}}else{if(h>maxSize){w=w*maxSize/h;h=maxSize;}}
        c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);
        resolve(c.toDataURL('image/jpeg',0.78));
      };
      img.src=e.target.result;
    };
    r.readAsDataURL(file);
  });
}
function renderAvatarHTML(m,size=48,fs=16){
  const c=getDeptColor(m.dept);
  const pts=m.points||0;
  const lv=getMemberLevel(pts);
  const lvIdx=LEVELS.indexOf(lv);
  // Higher levels shine more - generate dynamic glow based on level
  const glowSize = 8 + lvIdx * 4; // 8px at level 0, up to 44px at level 9
  const glowIntensity = 0.35 + lvIdx * 0.08; // stronger at higher levels
  const shimmer = lvIdx >= 5 ? `animation:avatarShine${lvIdx} ${2.5 - lvIdx*0.2}s ease-in-out infinite;` : '';
  const borderW = lvIdx >= 7 ? '3px' : '2px';
  const border=`${borderW} solid ${lv.color}`;
  const shadow=`box-shadow:0 0 ${glowSize}px rgba(${hexToRgb(lv.color)},${glowIntensity})${lvIdx>=8?`,0 0 ${glowSize*2}px rgba(${hexToRgb(lv.color)},0.25)`:''}`;
  const theme=m.animeTheme?ANIME_THEMES.find(t=>t.id===m.animeTheme):null;
  if(m.photo)return `<div class="avatar" style="width:${size}px;height:${size}px;border:${border};${shadow};${shimmer}position:relative"><img src="${m.photo}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%">${lvIdx>=6?`<div style="position:absolute;inset:-3px;border-radius:50%;background:conic-gradient(${lv.color},transparent,${lv.color});animation:spin ${1.5-lvIdx*0.1}s linear infinite;opacity:0.4;z-index:-1"></div>`:''}${lvIdx>=8?`<div style="position:absolute;inset:-6px;border-radius:50%;background:radial-gradient(circle,${lv.color}40,transparent 70%);animation:pulse 1.5s infinite;z-index:-2"></div>`:''}  </div>`;
  if(theme)return `<div class="avatar" style="width:${size}px;height:${size}px;background:${theme.colors[0]};border:${border};${shadow};font-size:${fs}px;${shimmer}">${theme.emoji}</div>`;
  return `<div class="avatar" style="width:${size}px;height:${size}px;background:${c}22;color:${c};border:${border};${shadow};font-size:${fs}px;${shimmer}">${escapeHTML(getInitials(m.name))}</div>`;
}
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}
