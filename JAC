let currentAppTheme = 'myprofile';

function applyAppTheme(themeId) {
  const theme = APP_THEMES.find(t => t.id === themeId) || APP_THEMES[0];
  currentAppTheme = theme.id;
  const root = document.documentElement;
  Object.entries(theme).forEach(([k,v]) => {
    if(k.startsWith('--')) root.style.setProperty(k, v);
  });
  // Save to localStorage
  try { localStorage.setItem('jac-app-theme', themeId); } catch(e){}
  // Update theme selector UI if open
  renderAppThemeGrid();
}

function loadAppTheme() {
  try {
    const saved = localStorage.getItem('jac-app-theme');
    applyAppTheme(saved || 'myprofile');
  } catch(e) { applyAppTheme('myprofile'); }
}

function openAppThemeModal() {
  renderAppThemeGrid();
  document.getElementById('app-theme-modal').classList.add('open');
}
function closeAppThemeModal() {
  document.getElementById('app-theme-modal').classList.remove('open');
}
function renderAppThemeGrid() {
  const el = document.getElementById('app-theme-grid');
  if(!el) return;
  el.innerHTML = APP_THEMES.map(t => `
    <div onclick="applyAppTheme('${t.id}')" style="cursor:pointer;border-radius:14px;padding:10px;border:2px solid ${currentAppTheme===t.id?'var(--accent)':'var(--border)'};background:${t['--bg-light']};transition:all .2s;text-align:center">
      <div style="font-size:24px;margin-bottom:4px">${t.icon}</div>
      <div style="display:flex;gap:3px;justify-content:center;margin-bottom:6px">
        <div style="width:12px;height:12px;border-radius:50%;background:${t['--primary']}"></div>
        <div style="width:12px;height:12px;border-radius:50%;background:${t['--accent']}"></div>
        <div style="width:12px;height:12px;border-radius:50%;background:${t['--bg']}"></div>
      </div>
      <div style="font-size:10px;font-weight:800;color:${currentAppTheme===t.id?t['--accent']:t['--text-secondary']}">${t.name}</div>
    </div>
  `).join('');
}

