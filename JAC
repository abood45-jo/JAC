// ── FINANCE ──
function changeFinanceMonth(dir){
  const inp=document.getElementById('finance-month');if(!inp)return;
  const [y,m]=inp.value.split('-').map(Number);
  const d=new Date(y,m-1+dir,1);
  inp.value=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
  onFinanceMonthChange();
}
function onFinanceMonthChange(){financeMonth=document.getElementById('finance-month')?.value||getCurrentMonth();initFinanceSession();renderFinance();}
function initFinanceSession(){
  financeMonth=document.getElementById('finance-month')?.value||getCurrentMonth();
  if(!sessions[financeMonth])sessions[financeMonth]={};
  const sd=sessions[financeMonth];
  members.filter(m=>m.dept===currentFinanceDept).forEach(m=>{if(!sd[m.id])sd[m.id]={attended:false,paid:0};});
}
function renderFinance(){
  const sd=sessions[financeMonth]||{},deptM=members.filter(m=>m.dept===currentFinanceDept);
  const aC=deptM.filter(m=>sd[m.id]?.attended).length;
  const cT=+deptM.reduce((s,m)=>s+(+(sd[m.id]?.paid||0)),0).toFixed(2);
  const lC=deptM.filter(m=>calculateMemberBalance(m).balance<0).length;
  document.getElementById('sess-attend').textContent=aC;
  document.getElementById('sess-collected').textContent=(+cT).toFixed(1);
  document.getElementById('sess-late').textContent=lC;
  document.getElementById('finance-list').innerHTML=deptM.map(m=>{
