    const tOverdue=totals.filter(t=>t.balance<0).reduce((s,t)=>s+Math.abs(t.balance),0);
    const pct=tReq>0?Math.round((tPaid/tReq)*100):0;
    const dateStr=new Date().toLocaleDateString('ar-JO',{year:'numeric',month:'long',day:'numeric'});

    let deptSections='';
