let animeTeam = [];
let currentAnimeFiltered = ANIME_LIST;
const ANIME_TEAM_MAX = 8;
const ANIME_COLORS = ['#166534','#1D4ED8','#0E7490','#7C3AED','#A21CAF','#DC2626','#EA580C','#BE185D','#0F766E','#B45309','#4338CA','#15803D','#9F1239','#0369A1','#65A30D','#C2410C'];
function colorForAnime(en){
  let h = 0;
  for(let i=0;i<en.length;i++) h = (h*31 + en.charCodeAt(i)) >>> 0;
  return ANIME_COLORS[h % ANIME_COLORS.length];
}

