// ── BALANCE ──
function calculateMemberBalance(m){
  let paid=+(m.lP||0),required=+(m.lR||0);
  Object.values(sessions).forEach(sd=>{if(sd&&sd[m.id]){required+=FEE_PER_MEMBER;paid+=+(sd[m.id].paid||0);}});
  (m.payments||[]).forEach(p=>{paid+=+(p.amount||0);});
  return{paid:+paid.toFixed(2),required:+required.toFixed(2),balance:+(paid-required).toFixed(2)};
}

