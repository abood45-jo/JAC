function addNote(id){
  const m=members.find(x=>x.id===id);if(!m)return;
  const inp=document.getElementById('note-input');
  const text=(inp?.value||'').trim();if(!text)return;
  if(!m.nList)m.nList=[];
  m.nList.push({id:genId(),text,date:new Date().toLocaleDateString('ar-JO'),ts:Date.now()});
  if(inp)inp.value='';saveData();showProfileModal();showToast('تمت إضافة الملاحظة');
}
function deleteNote(mId,nId){const m=members.find(x=>x.id===mId);if(m){m.nList=(m.nList||[]).filter(n=>n.id!==nId);saveData();showProfileModal();}}
function deletePayment(mId,pId){
  const m=members.find(x=>x.id===mId);if(!m)return;
  const p=(m.payments||[]).find(x=>x.id===pId);
  if(p)showConfirm(`حذف دفعة ${p.amount} د.أ؟`,()=>{m.payments=m.payments.filter(x=>x.id!==pId);saveData();showProfileModal();showToast('تم حذف الدفعة');});
}
function confirmDeleteMember(id){
  const m=members.find(x=>x.id===id);if(!m)return;
  showConfirm(`حذف ${m.name} نهائياً؟ لا يمكن التراجع.`,()=>{
    members=members.filter(x=>x.id!==id);
    Object.keys(sessions).forEach(k=>{if(sessions[k][id])delete sessions[k][id];});
    saveData();closeProfileModal();renderMembers();renderHome();showToast('تم حذف العضو');
  });
}

