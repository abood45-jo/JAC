function renderAnimeList(){
  const raw = document.getElementById('anime-search-input')?.value || '';
  const q = normalizeArabic(raw);
  const qEn = raw.toLowerCase().trim();
  const el = document.getElementById('personal-anime-list');
  if(!el) return;
  currentAnimeFiltered = (!q && !qEn) ? ANIME_LIST : ANIME_LIST.filter(a =>
    normalizeArabic(a.ar).includes(q) || a.en.toLowerCase().includes(qEn)
  );
  const countEl = document.getElementById('anime-list-count');
  if(countEl) countEl.textContent = `${animeTeam.length}/${ANIME_TEAM_MAX} في الفريق — ${currentAnimeFiltered.length} من ${ANIME_LIST.length} أنمي`;
  el.innerHTML = currentAnimeFiltered.map((a,i) => {
    const inTeam = animeTeam.some(t => t.en === a.en);
    const color = colorForAnime(a.en);
    return `
    <div onclick="toggleAnimeTeamByIndex(${i})" style="display:flex;align-items:center;gap:10px;padding:8px 11px;border-radius:12px;cursor:pointer;background:${inTeam?color:'var(--bg-lightest)'};border:1px solid ${inTeam?color:'var(--border)'}">
