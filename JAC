// ── EXPORT ──
function sanitizeSheetName(name, used){
  let clean = String(name||'Sheet').replace(/[:\\/?*\[\]]/g,' ').replace(/\s+/g,' ').trim();
  if(!clean) clean = 'Sheet';
  clean = clean.slice(0,31);
  let base = clean, i = 1;
  while(used.has(clean)){
    const suffix = ' '+(++i);
    clean = base.slice(0, 31-suffix.length)+suffix;
  }
  used.add(clean);
  return clean;
}
function exportToExcel(){
  if(typeof XLSX==='undefined'){showToast('مكتبة Excel غير محملة','error');return;}
  try{
    const wb=XLSX.utils.book_new();
    const usedNames=new Set();

    // ── Summary sheet ──
    const sumRows=[
      ['نادي اليابان والأنمي - JAC'],
      ['تقرير مالي شامل - '+new Date().toLocaleDateString('ar-JO')],
      [],
