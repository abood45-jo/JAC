function openThemePicker(ctx){
  _themeCtx=ctx;_themeGenre='';
  const inp=document.getElementById('theme-search-input');if(inp)inp.value='';
  renderThemeGenreTabs();renderThemeGrid();
  document.getElementById('theme-picker-modal').classList.add('open');
}
function closeThemePicker(){
  document.getElementById('theme-picker-modal').classList.remove('open');
  renderThemeMini(_themeCtx);
}
function clearThemeSelection(){ setThemeSel(_themeCtx,''); renderThemeGrid(); }
function filterThemeGenre(g){ _themeGenre=g; renderThemeGenreTabs(); renderThemeGrid(); }
function renderThemeGenreTabs(){
  const el=document.getElementById('theme-genre-tabs');if(!el)return;
  el.innerHTML=`<button class="cover-cat-btn${!_themeGenre?' active':''}" onclick="filterThemeGenre('')">🌟 الكل</button>`+
    ANIME_GENRES.map(g=>`<button class="cover-cat-btn${_themeGenre===g.id?' active':''}" onclick="filterThemeGenre('${g.id}')">${g.icon} ${g.name}</button>`).join('');
}
function renderThemeGrid(){
  const q=normalizeArabic((document.getElementById('theme-search-input')||{}).value||'');
  let list=ANIME_THEMES;
  if(_themeGenre) list=list.filter(t=>t.genre===_themeGenre);
  if(q) list=list.filter(t=>normalizeArabic(t.name).includes(q)||normalizeArabic(t.nameEn).includes(q));
  const sel=getThemeSel(_themeCtx);
  document.getElementById('theme-grid-container').innerHTML=list.map(t=>`
    <div class="theme-card${sel===t.id?' selected':''}" onclick="selectTheme('${t.id}')" style="${sel===t.id?'border-color:'+t.accent+';background:'+t.colors[0]:''};transition:all .2s">
      <div class="theme-icon">${t.emoji}</div>
      <div class="theme-name" style="color:${sel===t.id?t.accent:'var(--text-secondary)'}">${t.name}</div>
      <div class="theme-en">${t.nameEn}</div>
    </div>`).join('');
}
function selectTheme(id){ setThemeSel(_themeCtx,id); renderThemeGrid(); }
function renderThemeMini(ctx){
  const el=document.getElementById(`${ctx}-theme-mini`);if(!el)return;
  const sel=getThemeSel(ctx);
  const popular=['aot','naruto','demon','jjk','solo','op','mha','hxh'];
  el.innerHTML=popular.map(id=>{ const t=ANIME_THEMES.find(x=>x.id===id); if(!t)return'';
    return `<div class="theme-mini-item${sel===t.id?' selected':''}" onclick="setThemeSel('${ctx}','${t.id}');renderThemeMini('${ctx}')" style="background:${t.colors[0]};border-color:${sel===t.id?t.accent:'transparent'}" title="${t.name}">${t.emoji}</div>`;
  }).join('');
}

// ── Points Modal ──
let _pointsMemberId='';
function openPointsModal(id){
  _pointsMemberId=id;
  const m=members.find(x=>x.id===id);if(!m)return;
  document.getElementById('points-modal-title').textContent=`⭐ نقاط ${m.name}`;
  document.getElementById('modal-points-input').value=m.points||0;
  updatePointsDisplay();
  document.getElementById('points-modal').classList.add('open');
}
function closePointsModal(){ document.getElementById('points-modal').classList.remove('open'); }
function updatePointsDisplay(){
  const pts=parseInt(document.getElementById('modal-points-input').value||0);
  document.getElementById('points-level-display').innerHTML=renderLevelBadge(pts)+renderLevelBar(pts);
  const lv=getMemberLevel(pts);const nextIdx=LEVELS.indexOf(lv)+1;
  document.getElementById('points-next-info').textContent=nextIdx<LEVELS.length?`${LEVELS[nextIdx].max-pts+1} نقطة للوصول إلى ${LEVELS[nextIdx].name} ${LEVELS[nextIdx].icon}`:'🔱 وصلت للمستوى الأقصى!';
}
function adjustModalPoints(d){ const el=document.getElementById('modal-points-input');let v=Math.max(0,parseInt(el.value||0)+d);el.value=v;updatePointsDisplay(); }
function addFixedPoints(d){ const el=document.getElementById('modal-points-input');let v=Math.max(0,parseInt(el.value||0)+d);el.value=v;updatePointsDisplay(); }
function savePointsFromModal(){
  const m=members.find(x=>x.id===_pointsMemberId);if(!m)return;
  const pts=parseInt(document.getElementById('modal-points-input').value||0);
  const old=m.points||0; m.points=pts;
  saveData();closePointsModal();
  if(document.getElementById('profile-modal').classList.contains('open'))showProfileModal();
  renderMembers();showToast(`⭐ نقاط ${m.name}: ${pts} (${pts>=old?'+':''}${pts-old})`);
}
document.addEventListener('input',e=>{ if(e.target.id==='modal-points-input')updatePointsDisplay(); });

