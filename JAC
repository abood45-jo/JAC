function _loadImg(src){
  return new Promise((resolve)=>{
    if(!src){resolve(null);return;}
    const img=new Image();
    img.crossOrigin='anonymous';
    img.onload=()=>resolve(img);
    img.onerror=()=>resolve(null);
    img.src=src;
  });
}
function _roundRectPath(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}
async function exportMemberIDCard(id){
  const m=members.find(x=>x.id===id);if(!m){showToast('العضو غير موجود','error');return;}
  showToast('⏳ يتم تجهيز البطاقة...','info');
  try{
    const W=1200,H=1600; // 3:4 ratio, high resolution
    const canvas=document.createElement('canvas');
    canvas.width=W;canvas.height=H;
    const ctx=canvas.getContext('2d');

    const pts=m.points||0, lv=getMemberLevel(pts);
    const deptColor=getDeptColor(m.dept);
    const theme=m.animeTheme?ANIME_THEMES.find(t=>t.id===m.animeTheme):null;
    const coverObj=m.cover?getCover(m.cover):null;

    // 1) Background: cover photo (if any) else theme/dept gradient
    const bgGrad=ctx.createLinearGradient(0,0,W,H);
    if(theme&&theme.colors&&theme.colors.length>1){
      bgGrad.addColorStop(0,theme.colors[0]);bgGrad.addColorStop(1,theme.colors[1]||theme.colors[0]);
    }else{
      bgGrad.addColorStop(0,'#4C1D95');bgGrad.addColorStop(1,'#181428');
    }
    ctx.fillStyle=bgGrad;ctx.fillRect(0,0,W,H);

    if(coverObj){
      const coverImg=await _loadImg(coverDataUri(coverObj));
      if(coverImg){
        // cover fills the top ~46% of the card, like a banner
        const bannerH=H*0.46;
        const scale=Math.max(W/coverImg.width,bannerH/coverImg.height);
        const dw=coverImg.width*scale,dh=coverImg.height*scale;
        ctx.save();
        ctx.beginPath();ctx.rect(0,0,W,bannerH);ctx.clip();
        ctx.drawImage(coverImg,(W-dw)/2,(bannerH-dh)/2,dw,dh);
        ctx.restore();
        // fade banner into background color toward bottom
        const fade=ctx.createLinearGradient(0,bannerH*0.45,0,bannerH);
        fade.addColorStop(0,'rgba(10,8,22,0)');
        fade.addColorStop(1,'rgba(10,8,22,1)');
        ctx.fillStyle=fade;ctx.fillRect(0,0,W,bannerH);
      }
    }

    // subtle vignette overlay across whole card for legibility
    const vNorth=ctx.createLinearGradient(0,0,0,H*0.22);
    vNorth.addColorStop(0,'rgba(0,0,0,.25)');vNorth.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=vNorth;ctx.fillRect(0,0,W,H*0.22);

    // 2) Club brand header
    ctx.textAlign='center';
    ctx.fillStyle='rgba(255,255,255,.92)';
    ctx.font='900 40px Cairo, Tahoma, Arial, sans-serif';
    ctx.fillText('🎌 نادي اليابان والأنمي', W/2, 70);
    ctx.font='700 22px Cairo, Tahoma, Arial, sans-serif';
    ctx.fillStyle='rgba(255,255,255,.65)';
    ctx.fillText('JAPAN & ANIME CLUB — MEMBER ID', W/2, 105);

    // 3) Avatar (circular, centered, overlapping banner/body line)
    const avatarR=190, avatarCx=W/2, avatarCy=H*0.46;
    ctx.save();
    ctx.beginPath();ctx.arc(avatarCx,avatarCy,avatarR+14,0,Math.PI*2);
    ctx.fillStyle=lv.color;ctx.shadowColor=lv.color;ctx.shadowBlur=60;ctx.fill();
    ctx.restore();

    ctx.save();
    ctx.beginPath();ctx.arc(avatarCx,avatarCy,avatarR,0,Math.PI*2);ctx.closePath();ctx.clip();
    if(m.photo){
      const photoImg=await _loadImg(m.photo);
      if(photoImg){
        const s=Math.max((avatarR*2)/photoImg.width,(avatarR*2)/photoImg.height);
        const dw=photoImg.width*s,dh=photoImg.height*s;
        ctx.drawImage(photoImg,avatarCx-dw/2,avatarCy-dh/2,dw,dh);
      }else{
        ctx.fillStyle=(theme?theme.colors[0]:deptColor+'33');ctx.fillRect(avatarCx-avatarR,avatarCy-avatarR,avatarR*2,avatarR*2);
      }
    }else{
      ctx.fillStyle=theme?theme.colors[0]:deptColor+'33';
      ctx.fillRect(avatarCx-avatarR,avatarCy-avatarR,avatarR*2,avatarR*2);
      ctx.fillStyle=theme?'#fff':deptColor;
      ctx.font=(theme?'700 150px':'900 140px')+' Cairo, Tahoma, Arial, sans-serif';
      ctx.textBaseline='middle';
      ctx.fillText(theme?theme.emoji:getInitials(m.name), avatarCx, avatarCy+10);
      ctx.textBaseline='alphabetic';
    }
    ctx.restore();
    // avatar ring
    ctx.beginPath();ctx.arc(avatarCx,avatarCy,avatarR,0,Math.PI*2);
    ctx.lineWidth=10;ctx.strokeStyle=lv.color;ctx.stroke();

    // 4) Name
    ctx.fillStyle='#FFFFFF';
    ctx.font='900 58px Cairo, Tahoma, Arial, sans-serif';
    ctx.textAlign='center';
    ctx.fillText(m.name, W/2, avatarCy+avatarR+78);

    // 5) Department chip
    const deptText=`${getDeptIcon(m.dept)}  ${getDeptName(m.dept)}`;
    ctx.font='800 32px Cairo, Tahoma, Arial, sans-serif';
    const deptW=ctx.measureText(deptText).width+60;
    const deptY=avatarCy+avatarR+108;
    _roundRectPath(ctx,W/2-deptW/2,deptY,deptW,56,28);
    ctx.fillStyle=deptColor+'30';ctx.fill();
    ctx.lineWidth=2;ctx.strokeStyle=deptColor;ctx.stroke();
    ctx.fillStyle=deptColor;
    ctx.fillText(deptText, W/2, deptY+38);

    // 6) Level badge + anime theme chip (side by side)
    const chipY=deptY+90;
    const lvText=`${lv.icon}  ${lv.name} (${lv.nameEn}) • ${pts} نقطة`;
    ctx.font='800 30px Cairo, Tahoma, Arial, sans-serif';
    const lvW=ctx.measureText(lvText).width+56;
    _roundRectPath(ctx,W/2-lvW/2,chipY,lvW,52,26);
    ctx.fillStyle=lv.color+'25';ctx.fill();
    ctx.lineWidth=2;ctx.strokeStyle=lv.color;ctx.stroke();
    ctx.fillStyle=lv.color;
    ctx.fillText(lvText, W/2, chipY+35);

    let nextY=chipY+82;
    if(theme){
      const themeText=`${theme.emoji}  ${theme.name}`;
      ctx.font='700 26px Cairo, Tahoma, Arial, sans-serif';
      const thW=ctx.measureText(themeText).width+48;
      _roundRectPath(ctx,W/2-thW/2,nextY,thW,46,23);
      ctx.fillStyle=(theme.accent||'#fff')+'22';ctx.fill();
      ctx.lineWidth=1.5;ctx.strokeStyle=theme.accent||'#fff';ctx.stroke();
      ctx.fillStyle=theme.accent||'#fff';
      ctx.fillText(themeText, W/2, nextY+31);
      nextY+=70;
    }

    // 7) Footer
    ctx.font='700 22px Cairo, Tahoma, Arial, sans-serif';
    ctx.fillStyle='rgba(255,255,255,.55)';
    ctx.fillText('JAC Jordan • '+new Date().toLocaleDateString('ar-JO'), W/2, H-40);

    // decorative thin border
    ctx.lineWidth=4;ctx.strokeStyle='rgba(255,255,255,.12)';
    ctx.strokeRect(8,8,W-16,H-16);

    // download
    canvas.toBlob(blob=>{
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');
      a.href=url;
      a.download=`JAC_ID_${m.name.replace(/\s+/g,'_')}.png`;
      document.body.appendChild(a);a.click();document.body.removeChild(a);
      setTimeout(()=>URL.revokeObjectURL(url),3000);
      showToast('✓ تم تصدير البطاقة الشخصية');
    },'image/png',1);
  }catch(e){
    showToast('خطأ في تصدير البطاقة: '+e.message,'error');
  }
}


