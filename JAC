function vibrate(ms=40){try{if(navigator.vibrate)navigator.vibrate(ms);}catch(e){}}
document.addEventListener('click',e=>{
  if(e.target.closest('.button,.nav-btn,.tab,.member-row,.jac-action-item,.quick-btn'))vibrate(35);
});

// ── KEYBOARD SHORTCUTS ──
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='SELECT')return;
  const shortcuts={'1':'home','2':'members','3':'finance','4':'calendar','5':'reports'};
  if(shortcuts[e.key])goToPage(shortcuts[e.key]);
  if(e.key==='Escape'){
    document.querySelectorAll('.modal.open').forEach(m=>m.classList.remove('open'));
  }
  if((e.ctrlKey||e.metaKey)&&e.key==='f'){
    e.preventDefault();
    goToPage('members');
    setTimeout(()=>document.getElementById('search-members')?.focus(),200);
  }
  if((e.ctrlKey||e.metaKey)&&e.key==='s'){
    e.preventDefault();
    saveData();
    showToast('✓ تم الحفظ');
  }
});

// ── SWIPE NAVIGATION ──
(function(){
  let sx=0,sy=0,st=0;
  const pages=['home','members','finance','calendar','reports'];
  document.getElementById('app').addEventListener('touchstart',e=>{
    const t=e.touches[0];sx=t.clientX;sy=t.clientY;st=Date.now();
  },{passive:true});
  document.getElementById('app').addEventListener('touchend',e=>{
    if(document.querySelector('.modal.open'))return;
    const t=e.changedTouches[0];
    const dx=t.clientX-sx,dy=t.clientY-sy,dt=Date.now()-st;
    if(Math.abs(dx)>60&&Math.abs(dy)<50&&dt<400){
      const idx=pages.indexOf(currentPage);
      if(dx<0&&idx<pages.length-1)goToPage(pages[idx+1]);
      else if(dx>0&&idx>0)goToPage(pages[idx-1]);
    }
  },{passive:true});
})();

