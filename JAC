    ];
    let grandReq=0,grandPaid=0,grandCount=0;
    DEPARTMENTS.forEach(d=>{
      const dm=members.filter(m=>m.dept===d.id);
      const dt=dm.map(m=>calculateMemberBalance(m));
      const p=dt.reduce((s,t)=>s+t.paid,0), r=dt.reduce((s,t)=>s+t.required,0);
      grandReq+=r; grandPaid+=p; grandCount+=dm.length;
      sumRows.push([d.name,dm.length,r,p,p-r]);
    });
    sumRows.push(['الإجمالي',grandCount,grandReq,grandPaid,grandPaid-grandReq]);

    const sumWs=XLSX.utils.aoa_to_sheet(sumRows);
    for(let r=5;r<=sumRows.length;r++){
      ['C','D','E'].forEach(col=>{const addr=col+r; if(sumWs[addr]&&typeof sumWs[addr].v==='number') sumWs[addr].z='#,##0.00';});
    }
    sumWs['!cols']=[{wch:30},{wch:14},{wch:16},{wch:16},{wch:16}];
    sumWs['!merges']=[{s:{r:0,c:0},e:{r:0,c:4}},{s:{r:1,c:0},e:{r:1,c:4}}];
    sumWs['!views']=[{rightToLeft:true}];
    XLSX.utils.book_append_sheet(wb,sumWs,sanitizeSheetName('الملخص',usedNames));

    // ── Per-department detail sheets ──
    DEPARTMENTS.forEach(d=>{
      const dm=members.filter(m=>m.dept===d.id);
      if(!dm.length)return;
      const rows=[['الاسم','المطلوب','المسدد','الرصيد','الحالة','الميلاد','الهاتف','الإيميل']];
      dm.forEach(m=>{
        const b=calculateMemberBalance(m);
        rows.push([m.name,b.required,b.paid,b.balance,b.balance>=0?'مسدد':b.paid>0?'جزئي':'متأخر',m.dob||'',m.phone||'',m.email||'']);
      });
      const ws=XLSX.utils.aoa_to_sheet(rows);
      for(let r=2;r<=rows.length;r++){
        ['B','C','D'].forEach(col=>{const addr=col+r; if(ws[addr]&&typeof ws[addr].v==='number') ws[addr].z='#,##0.00';});
      }
      ws['!cols']=[{wch:22},{wch:10},{wch:10},{wch:10},{wch:10},{wch:12},{wch:14},{wch:22}];
      ws['!autofilter']={ref:XLSX.utils.encode_range({s:{r:0,c:0},e:{r:rows.length-1,c:7}})};
      ws['!views']=[{rightToLeft:true}];
      XLSX.utils.book_append_sheet(wb,ws,sanitizeSheetName(d.name,usedNames));
    });

    XLSX.writeFile(wb,`JAC_Report_${new Date().toISOString().slice(0,10)}.xlsx`);
    showToast('✓ تم تصدير Excel بنجاح');
  }catch(e){showToast('خطأ في Excel: '+e.message,'error');}
}
async function exportToPDF(){
